<?xml version="1.0" ?>
<sdf version="1.6">
  <world name="vla_6g_demo">
    <physics name="4ms" type="ignored">
      <max_step_size>0.004</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>

    <plugin filename="gz-sim-physics-system" name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim-user-commands-system" name="gz::sim::systems::UserCommands"/>

    <!-- Sky / atmosphere -->
    <scene>
      <ambient>0.6 0.6 0.7 1</ambient>
      <background>0.4 0.6 0.9 1</background>
      <shadows>true</shadows>
    </scene>

    <!-- Sun -->
    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>
      <pose>30 30 80 0 0 0</pose>
      <diffuse>1.0 0.95 0.85 1</diffuse>
      <specular>0.5 0.5 0.5 1</specular>
      <attenuation>
        <range>1000</range>
        <constant>0.9</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
      <direction>-0.4 0.2 -0.8</direction>
    </light>

    <!-- Fill light (softer, opposite side) -->
    <light type="directional" name="fill_light">
      <cast_shadows>false</cast_shadows>
      <pose>-30 -30 60 0 0 0</pose>
      <diffuse>0.3 0.35 0.45 1</diffuse>
      <specular>0.1 0.1 0.1 1</specular>
      <direction>0.4 -0.2 -0.6</direction>
    </light>

    <!-- ============ GROUND ============ -->
    <!-- Main grass field -->
    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry><plane><normal>0 0 1</normal><size>200 200</size></plane></geometry>
        </collision>
        <visual name="visual">
          <geometry><plane><normal>0 0 1</normal><size>200 200</size></plane></geometry>
          <material>
            <ambient>0.25 0.4 0.2 1</ambient>
            <diffuse>0.3 0.45 0.25 1</diffuse>
            <specular>0.05 0.05 0.05 1</specular>
          </material>
        </visual>
      </link>
      <pose>50 50 0 0 0 0</pose>
    </model>

    <!-- Concrete pad around BS -->
    <model name="bs_pad">
      <static>true</static>
      <link name="link">
        <visual name="visual">
          <geometry><box><size>12 12 0.05</size></box></geometry>
          <material>
            <ambient>0.5 0.5 0.5 1</ambient>
            <diffuse>0.55 0.55 0.55 1</diffuse>
          </material>
        </visual>
      </link>
      <pose>0 0 0.025 0 0 0</pose>
    </model>

    <!-- Road X-axis (from BS toward users) -->
    <model name="road_x">
      <static>true</static>
      <link name="link">
        <visual name="visual">
          <geometry><box><size>120 6 0.02</size></box></geometry>
